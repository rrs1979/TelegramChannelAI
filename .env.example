# Server
PORT=5000
FLASK_ENV=development
FLASK_SECRET=change-this-in-production

# Bind address (default 0.0.0.0). Set to 127.0.0.1 if you're behind nginx.
# HOST=127.0.0.1

# Database (defaults to web/data.db)
# DB_PATH=/path/to/data.db

# Pipeline auto-run interval in seconds (default 1h)
# PIPELINE_INTERVAL=3600

# Pipeline mode: "auto" or "semi-auto" (default semi-auto)
# PIPELINE_MODE=semi-auto

# Hours to look back when checking for duplicate posts (default 48)
# DEDUP_HOURS=48

# Hours to look back when scanning source channels for new posts (default 2)
# SCAN_HOURS=2

# Generated image dimensions in pixels (default 768x432, 16:9). Pollinations caps at 2048.
# IMAGE_WIDTH=768
# IMAGE_HEIGHT=432

# Log level: DEBUG, INFO, WARNING, ERROR (default DEBUG in dev, INFO in prod)
# LOG_LEVEL=INFO

# Max bytes per app.log file before rotation (default 1_000_000 = 1MB)
# LOG_MAX_BYTES=5000000

# How many rotated app.log files to keep (default 3)
# LOG_BACKUP_COUNT=5

# Telegram credentials
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_SESSION=

# Target channel
CHANNEL_ID=

# Pollinations API key (optional, for image generation)
# POLLINATIONS_API_KEY=

# Default source channels to monitor (comma-separated, overrides built-in list)
# DEFAULT_SOURCES=truexanewsua,u_now,voynareal,UaOnlii

# Multi-channel config (JSON, overrides single CHANNEL_ID above)
# CHANNEL_CONFIGS={"my_channel": {"channel_id": -100123, "prompt": "..."}}
