# Server
PORT=5000
FLASK_ENV=development
FLASK_SECRET=change-this-in-production

# Bind address (default 0.0.0.0). Set to 127.0.0.1 if you're behind nginx.
# HOST=127.0.0.1

# HTTP Basic Auth for the dashboard. Leave DASHBOARD_PASSWORD empty to keep it open
# (fine on localhost); set it to lock down anything exposed on 0.0.0.0.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=

# Database (defaults to web/data.db)
# DB_PATH=/path/to/data.db

# Pipeline auto-run interval in seconds (default 1h)
# PIPELINE_INTERVAL=3600

# Pipeline mode: "auto" or "semi-auto" (default semi-auto)
# PIPELINE_MODE=semi-auto

# Hours to look back when checking for duplicate posts (default 48)
# DEDUP_HOURS=48

# Fuzzy near-duplicate threshold (Jaccard headline token overlap, default 0.7).
# Catches the same story reworded by a different source past the exact md5 hash.
# Set to 0 to disable and use exact matching only.
# NEAR_DUP_THRESHOLD=0.7

# Hours to look back when scanning source channels for new posts (default 2)
# SCAN_HOURS=2

# Generated image dimensions in pixels (default 768x432, 16:9). Pollinations caps at 2048.
# IMAGE_WIDTH=768
# IMAGE_HEIGHT=432

# Model used for the main rewrite step (default claude). Any model the Pollinations
# OpenAI-compatible endpoint exposes, e.g. openai, mistral.
# TEXT_MODEL=claude

# Pollinations image model (default flux). Try "turbo" for faster, lower-quality images.
# IMAGE_MODEL=flux

# Seconds to wait on a text generation call before giving up (default 30).
# Bump it if the model keeps timing out on longer posts.
# AI_TIMEOUT=30

# Seconds to wait on an image generation call before giving up (default 120).
# Image gen is much slower than text, so it gets its own longer timeout.
# IMAGE_TIMEOUT=120

# SOCKS proxy for image generation, in case Pollinations is blocked in your region.
# Needs aiohttp_socks installed. Example: socks5://127.0.0.1:1080
# IMAGE_PROXY=

# Log level: DEBUG, INFO, WARNING, ERROR (default DEBUG in dev, INFO in prod)
# LOG_LEVEL=INFO

# Max bytes per app.log file before rotation (default 1_000_000 = 1MB)
# LOG_MAX_BYTES=5000000

# How many rotated app.log files to keep (default 3)
# LOG_BACKUP_COUNT=5

# Telegram credentials
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telethon StringSession — generate by running a Telethon login once
TELEGRAM_SESSION=

# Target channel
CHANNEL_ID=

# Pollinations API key (optional, for image generation)
# POLLINATIONS_API_KEY=

# Pollinations API base URL. Override to use a mirror or a local proxy.
# POLLINATIONS_BASE_URL=https://gen.pollinations.ai

# Default source channels to monitor (comma-separated, overrides built-in list)
# DEFAULT_SOURCES=truexanewsua,u_now,voynareal,UaOnlii

# Multi-channel config (JSON, overrides single CHANNEL_ID above)
# CHANNEL_CONFIGS={"my_channel": {"channel_id": -100123, "prompt": "..."}}
